# Copy this file to services/api/.env (or a root .env) and adjust as needed.
# This file documents the connection details used by docker compose and Drizzle.

# PostgreSQL connection string (matches compose.yaml).
DATABASE_URL=postgres://uhyc:uhyc_dev@localhost:5432/uhyc

# Secret used to sign/verify auth JWTs. CHANGE THIS for any non-local environment.
JWT_SECRET=dev-secret-change-me

# Bailian (Aliyun Model Studio) API Key + base URL for generation calls.
BAILIAN_API_KEY=replace-with-real-key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# Aliyun OSS — for persisting uploaded reference materials and generated results.
# Leave unset for local-only development (files stored on disk, Bailian won't be
# able to reach them, so generation tasks will fail at runtime).
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
# Top-level folder in the bucket, e.g. "uhyc" → files go under uhyc/uploads/...
OSS_UPLOAD_PREFIX=uhyc
# Optional — overrides the auto-constructed public URL (e.g. for custom domain).
# OSS_PUBLIC_URL=https://your-custom-domain.com
