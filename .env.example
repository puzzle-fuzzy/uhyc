# Copy this file to services/api/.env (or a root .env) and adjust as needed.
# This file documents the connection details used by docker compose and Drizzle.

# PostgreSQL connection string (matches compose.yaml).
DATABASE_URL=postgres://uhyc:uhyc_dev@localhost:5432/uhyc

# Secret used to sign/verify auth JWTs. CHANGE THIS for any non-local environment.
JWT_SECRET=change-me-in-prod

# Bailian (Aliyun Model Studio) API Key + base URL for generation calls.
BAILIAN_API_KEY=replace-with-real-key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
